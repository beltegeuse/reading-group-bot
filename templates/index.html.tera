{% extends "base" %}
  
{% block content %}
  {% if flash %}
  <div class="notification is-{{flash.0}}">
    <button class="delete"></button>
    {{ flash.1 }}
  </div>
  {% endif %}

  <div class="content mb-5">
    {% if cookie_info %}
      <p>Please propose new papers and use Up if you are interested or Ignore if you are not.</p>
    {% else %}
      <p>Please register and login to vote and propose new papers.</p>
    {% endif %}
  </div>

  <div class="box mb-4">
    <form action="/" method="get">
      <div class="field has-addons">
        <div class="control is-expanded">
          <input class="input" type="text" name="q" value="{{ search_query }}" placeholder="Search papers by title, venue, or year">
        </div>
        <div class="control">
          <button class="button is-link" type="submit">Search</button>
        </div>
        {% if search_query or only_not_voted %}
        <div class="control">
          <a class="button is-light" href="/">Clear</a>
        </div>
        {% endif %}
      </div>
      <div class="field mt-2">
        <label class="checkbox">
          <input id="only-not-voted-toggle" type="checkbox" name="only_not_voted" value="1" {% if only_not_voted %}checked{% endif %}>
          Only show papers not voted yet
        </label>
      </div>
    </form>
  </div>

  <article id="dynamic-no-results" class="message is-warning is-hidden mb-4">
    <div class="message-body">
      No papers match the current filters.
    </div>
  </article>

  {% if papers | length == 0 %}
    <article class="message is-warning">
      <div class="message-body">
        No papers found{% if search_query %} for "{{ search_query }}"{% endif %}.
      </div>
    </article>
  {% endif %}

  {% for item in papers %}
    <div class="box mb-4 paper-card" data-vote-state="{{ item.vote_state }}">
      <div class="columns is-multiline">
        <div class="column is-narrow">
          {% if item.paper.thumbnail %}
            <figure class="image is-200x280">
              <img src="/thumbnails/{{item.paper.thumbnail}}" alt="{{item.paper.title}}" style="object-fit: cover; width: 100%; height: 100%;">
            </figure>
          {% else %}
            <figure class="image is-200x280" style="display: flex; align-items: center; justify-content: center;">
              <span class="icon is-large">
                <i class="fas fa-4x fa-file-pdf"></i>
              </span>
            </figure>
          {% endif %}
        </div>

        <div class="column">
          <div class="content">
            <p class="mb-2">
              <span class="icon-text">
                <span class="icon">
                  <i class="fas fa-book"></i>
                </span>
                <span>
                  {% if item.paper.pdf_file %}
                    <a href="/pdfs/{{item.paper.pdf_file}}" target="_blank"><strong>{{ item.paper.title }}</strong></a>
                    <span class="tag is-warning is-light ml-2">
                      <span class="icon is-small">
                        <i class="fas fa-file-pdf"></i>
                      </span>
                      <span>PDF</span>
                    </span>
                    {% if item.paper.url %}
                      <a href="{{item.paper.url}}" target="_blank" class="ml-2">Project page</a>
                    {% endif %}
                  {% elif item.paper.url %}
                    <a href="{{item.paper.url}}" target="_blank"><strong>{{ item.paper.title }}</strong></a>
                  {% else %}
                    <strong>{{ item.paper.title }}</strong>
                  {% endif %}
                </span>
              </span>
            </p>
            <p class="mb-2">
              <span class="tags has-addons">
                {% if item.paper.venue %}
                  <span class="tag">{{ item.paper.venue }}</span>
                {% endif %}
                {% if item.paper.publication_year %}
                  <span class="tag is-info">{{ item.paper.publication_year }}</span>
                {% endif %}
                <span class="tag is-light">Added {{ item.paper.added_at }}</span>
                <span class="tag is-link is-light">Votes {{ item.paper.vote_count }}</span>
              </span>
            </p>
            <p class="mb-3">
              <span class="tag is-grey is-light">
                <span class="icon is-small">
                  <i class="fas fa-user"></i>
                </span>
                <span>Proposed by {{ item.username }}</span>
              </span>
            </p>

            {% if cookie_info %}
              <div class="field is-grouped">
                <div class="control">
                  <form action="/paper/up/{{item.paper.id}}" method="post" style="display: inline;">
                    <input type="hidden" name="_method" value="put" />
                    <button class="button is-success is-small {% if item.vote_state != 1 %}is-outlined{% endif %}" type="submit" {% if item.vote_state == 1 %}disabled{% endif %}>
                      Up (Interested)
                    </button>
                  </form>
                </div>

                <div class="control">
                  <form action="/paper/down/{{item.paper.id}}" method="post" style="display: inline;">
                    <input type="hidden" name="_method" value="put" />
                    <button class="button is-danger is-small {% if item.vote_state == -1 %}is-outlined{% else %}is-light{% endif %}" type="submit" {% if item.vote_state == -1 %}disabled{% endif %}>
                      Ignore
                    </button>
                  </form>
                </div>

                <div class="control">
                  {% if item.vote_state == 1 %}
                    <span class="tag is-success is-light">You marked this paper as interested</span>
                  {% elif item.vote_state == -1 %}
                    <span class="tag is-danger is-light">You marked this paper as ignored</span>
                  {% else %}
                    <span class="tag is-light">You have not voted yet</span>
                  {% endif %}
                </div>

                {% if item.paper.user_id == cookie_info.id or cookie_info.is_admin %}
                  <div class="control">
                    <a class="button is-small is-info is-outlined" href="/paper/edit/{{item.paper.id}}">
                      <span class="icon is-small">
                        <i class="fas fa-pen"></i>
                      </span>
                      <span>Edit</span>
                    </a>
                  </div>
                  <div class="control">
                    <form action="/paper/remove/{{item.paper.id}}" method="post" style="display: inline;">
                      <input type="hidden" name="_method" value="put" />
                      <button class="button is-small is-danger is-outlined" type="submit">
                        <span class="icon is-small">
                          <i class="fas fa-trash-alt"></i>
                        </span>
                        <span>Remove</span>
                      </button>
                    </form>
                  </div>
                {% endif %}
              </div>
            {% else %}
              <div class="field">
                <div class="control">
                  <div class="button is-static is-small">
                    <span class="icon is-small">
                      <i class="fas fa-thumbs-up"></i>
                    </span>
                    <span>{{ item.paper.vote_count }}</span>
                  </div>
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  {% endfor %}

{% endblock content %}